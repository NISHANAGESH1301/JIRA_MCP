from datetime import datetime, timedelta
from collections import Counter

@mcp.tool()
async def get_issue_trend(projectKey: str, months: int = 6):
    """
    Get issue creation trend for a project over last N months
    """

    try:
        # Fetch high priority issues (reuse your service)
        issues = search_high_priority_issues(projectKey)

        if not issues:
            return {"message": "No issues found"}

        cutoff_date = datetime.utcnow() - timedelta(days=30 * months)

        month_list = []

        for issue in issues:
            created = issue["fields"]["created"][:10]  # yyyy-mm-dd
            dt = datetime.strptime(created, "%Y-%m-%d")

            if dt >= cutoff_date:
                month_list.append(dt.strftime("%Y-%m"))

        monthly_counts = dict(Counter(month_list))

        # Simple trend detection
        values = list(monthly_counts.values())

        trend = "Stable"
        if len(values) >= 2:
            if values[-1] > values[0]:
                trend = "Increasing"
            elif values[-1] < values[0]:
                trend = "Decreasing"

        return {
            "project": projectKey,
            "months_analyzed": months,
            "total_issues_considered": len(month_list),
            "monthly_counts": monthly_counts,
            "trend": trend
        }

    except Exception as e:
        return {"error": str(e)}